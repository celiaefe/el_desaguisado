# Desarrollo local:
# - Puedes dejar DATABASE_URL sin definir y la app usara instance/el_desaguisado.db.
# - SECRET_KEY puede ser un valor sencillo mientras desarrollas.
#
# Produccion en Vercel:
# - Define SECRET_KEY con un valor largo y privado.
# - Define DATABASE_URL con la URL de PostgreSQL persistente.

FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-secret-key
UPLOAD_FOLDER=static/uploads

# DATABASE_URL=postgresql://usuario:password@host:5432/base_de_datos
